{
  "name": "travel-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite --open",
    "start:host": "vite --host 0.0.0.0 --open",
    "build": "vite build",
    "preview": "vite preview",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npm run android:sync && npx cap open android",
    "android:apk": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:apk:local": "bash scripts/build-apk-local.sh",
    "apk:cachyos": "bash scripts/build-apk-cachyos.sh",
    "android:setup:cachyos": "bash scripts/install-android-studio-cachyos.sh",
    "test:demo": "node scripts/validate-demo-data.mjs",
    "test:unit": "node --test scripts/unit-tests.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@react-three/fiber": "^9.6.0",
    "country-state-city": "^3.2.1",
    "framer-motion": "^12.12.1",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.0"
  }
}
